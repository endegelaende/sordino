# ──────────────────────────────────────────────────────────────────────────────
# MANIFEST.in — Source distribution (sdist) inclusions for Sordino
# ──────────────────────────────────────────────────────────────────────────────

# Documentation
include LICENSE
include README.md
include CHANGELOG.md

# Package configuration
include pyproject.toml

# Fonts and splash assets (outside the jive package tree)
recursive-include share/jive/fonts *.ttf
recursive-include share/jive/jive *.png *.txt

# Wallpaper images bundled in the jive package
recursive-include jive/applets/SetupWallpaper/wallpaper *.png

# Applet localisation strings
recursive-include jive/applets */strings.txt

# Bundled assets (if present after release workflow asset bundling)
recursive-include jive/data *.ttf *.png *.jpg *.bmp *.txt

# CI
include .github/workflows/ci.yml

# Exclude byte-compiled files and caches
global-exclude *.pyc
global-exclude *.pyo
global-exclude __pycache__
global-exclude .DS_Store
global-exclude *.egg-info
